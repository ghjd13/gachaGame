<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0B9E5A"
    android:clipChildren="false"
    tools:context=".BattleActivity">

    <!-- ==================== [좌측: 아군 캐릭터 영역] ==================== -->

    <!-- ==================== [우측: 적 캐릭터 영역] ==================== -->
    <LinearLayout
        android:id="@+id/layout_allies"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="28dp"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <!-- 캐릭터 1 -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:gravity="center_horizontal"
            android:orientation="vertical">
            <!-- 코스트 (별 5개, 왼쪽 정렬) -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="start"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@android:drawable/btn_star_big_on"
                    app:tint="#FFFFFF" />

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@android:drawable/btn_star_big_on"
                    app:tint="#FFFFFF" />

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@android:drawable/btn_star_big_off"
                    app:tint="#757575" />

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@android:drawable/btn_star_big_off"
                    app:tint="#757575" />

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@android:drawable/btn_star_big_off"
                    app:tint="#757575" />
            </LinearLayout>
            <!-- 체력바 -->
            <ProgressBar
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="80dp"
                android:layout_height="10dp"
                android:progress="100"
                android:progressTint="#FFFFFF" />
            <!-- 캐릭터 이미지 -->
            <ImageView
                android:layout_width="100dp"
                android:layout_height="130dp"
                android:layout_marginTop="4dp"
                
                android:scaleType="fitCenter"
                android:src="@drawable/character_1_ld" />
        </LinearLayout>

        <!-- 캐릭터 2 -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:gravity="center_horizontal"
            android:orientation="vertical">
            <!-- 코스트 (별 5개, 왼쪽 정렬) -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="start"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@android:drawable/btn_star_big_on"
                    app:tint="#FFFFFF" />

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@android:drawable/btn_star_big_on"
                    app:tint="#FFFFFF" />

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@android:drawable/btn_star_big_off"
                    app:tint="#757575" />

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@android:drawable/btn_star_big_off"
                    app:tint="#757575" />

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@android:drawable/btn_star_big_off"
                    app:tint="#757575" />
            </LinearLayout>

            <ProgressBar
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="80dp"
                android:layout_height="10dp"
                android:progress="70"
                android:progressTint="#FFFFFF" />

            <ImageView
                android:layout_width="100dp"
                android:layout_height="130dp"
                android:layout_marginTop="4dp"
                android:scaleType="fitCenter"
                android:src="@drawable/character_1_ld" />
        </LinearLayout>

        <!-- 캐릭터 3 -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical">
            <!-- 코스트 (별 5개, 왼쪽 정렬) -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="start"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@android:drawable/btn_star_big_on"
                    app:tint="#FFFFFF" />

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@android:drawable/btn_star_big_on"
                    app:tint="#FFFFFF" />

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@android:drawable/btn_star_big_on"
                    app:tint="#FFFFFF" />

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@android:drawable/btn_star_big_off"
                    app:tint="#757575" />

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@android:drawable/btn_star_big_off"
                    app:tint="#757575" />
            </LinearLayout>

            <ProgressBar
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="80dp"
                android:layout_height="10dp"
                android:progress="40"
                android:progressTint="#FFFFFF" />

            <ImageView
                android:layout_width="100dp"
                android:layout_height="130dp"
                android:layout_marginTop="4dp"
                
                android:scaleType="fitCenter"
                android:src="@drawable/character_1_ld" />
        </LinearLayout>

    </LinearLayout>

    <LinearLayout
        android:id="@+id/layout_enemy"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="64dp"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_launcher_foreground" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:text="적 몬스터"
            android:textColor="#000000"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- ==================== [하단: 카드 영역] ==================== -->
    <!-- 3장의 카드 컨테이너 -->
    <!-- 수정됨: 높이를 160dp로 늘리고, 카드를 하단 정렬(gravity="bottom")하여 위로 올라갈 여백을 마련함 -->
    <LinearLayout
        android:id="@+id/layout_cards"
        android:layout_width="wrap_content"
        android:layout_height="160dp"
        android:layout_marginEnd="32dp"
        android:layout_marginBottom="32dp"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:gravity="bottom"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/btn_next_turn">

        <!-- 카드 1 (ImageView로 변경) -->
        <ImageView
            android:id="@+id/card1"
            android:layout_width="80dp"
            android:layout_height="120dp"
            android:layout_marginEnd="8dp"
            android:background="#B3E5FC"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_launcher_foreground" />

        <!-- 카드 2 (ImageView로 변경) -->
        <ImageView
            android:id="@+id/card2"
            android:layout_width="80dp"
            android:layout_height="120dp"
            android:layout_marginEnd="8dp"
            android:background="#4FC3F7"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_launcher_foreground" />

        <!-- 카드 3 (ImageView로 변경) -->
        <ImageView
            android:id="@+id/card3"
            android:layout_width="80dp"
            android:layout_height="120dp"
            android:background="#0288D1"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_launcher_foreground" />
    </LinearLayout>

    <!-- 다음 턴 버튼 -->
    <Button
        android:id="@+id/btn_next_turn"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="64dp"
        android:layout_marginBottom="32dp"
        android:backgroundTint="#154360"
        android:text="다음 턴"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>