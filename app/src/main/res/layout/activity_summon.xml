<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/summon_bg"
    tools:context=".SummonActivity">

    <!-- 좌측의 진한 녹색 세로줄 -->
    <View
        android:id="@+id/view_left_stripe"
        android:layout_width="40dp"
        android:layout_height="match_parent"
        android:layout_marginStart="40dp"
        android:background="#4087CEFA"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- 뒤로 가기 버튼 추가 -->

    <!-- ==================== [좌측 탭 메뉴 (이미지 권장)] ==================== -->
    <!-- 디자이너가 추출한 '픽업 소환.png', '일반 소환.png'를 사용하세요 -->

    <ImageView
        android:id="@+id/btn_back"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginStart="35dp"
        android:layout_marginTop="30dp"
        android:background="@drawable/bg_circle_btn"
        android:padding="12dp"
        android:src="@android:drawable/ic_menu_revert"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/tab_pickup_summon"
        android:layout_width="150dp"
        android:layout_height="75dp"
        android:layout_marginStart="30dp"
        android:layout_marginTop="10dp"
        android:scaleType="fitCenter"
        android:src="@drawable/summon_btn_pickup"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/btn_back" />

    <ImageView
        android:id="@+id/tab_normal_summon"
        android:layout_width="150dp"
        android:layout_height="75dp"
        android:layout_marginStart="30dp"
        android:layout_marginTop="10dp"
        android:scaleType="fitCenter"
        android:src="@drawable/summon_btn_normal"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tab_pickup_summon" />

    <!-- ==================== [중앙/우측 가챠 배너 이미지] ==================== -->

    <ImageView
        android:id="@+id/img_summon_banner"
        android:layout_width="427dp"
        android:layout_height="240dp"
        android:layout_marginStart="30dp"
        android:layout_marginTop="100dp"
        android:layout_marginEnd="40dp"
        android:layout_marginBottom="120dp"
        android:scaleType="centerCrop"
        android:src="@drawable/summon_banner_pickup"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/view_left_stripe"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.697" />

    <!-- ==================== [우측 하단 버튼 영역] ==================== -->

    <!-- 10회 소환 버튼 -->
    <TextView
        android:id="@+id/btn_summon_10"
        android:layout_width="140dp"
        android:layout_height="60dp"
        android:layout_marginTop="30dp"
        android:layout_marginEnd="-30dp"
        android:layout_marginBottom="30dp"
        android:background="@drawable/bg_summon_action_btn"
        android:gravity="center"
        android:text="10회 소환"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="@+id/img_summon_banner"
        app:layout_constraintTop_toBottomOf="@+id/img_summon_banner" />

    <!-- 1회 소환 버튼 -->
    <TextView
        android:id="@+id/btn_summon_1"
        android:layout_width="120dp"
        android:layout_height="60dp"
        android:layout_marginEnd="16dp"
        android:background="@drawable/bg_summon_action_btn"
        android:gravity="center"
        android:text="1회 소환"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@+id/btn_summon_10"
        app:layout_constraintEnd_toStartOf="@+id/btn_summon_10"
        app:layout_constraintTop_toTopOf="@+id/btn_summon_10" />

</androidx.constraintlayout.widget.ConstraintLayout>